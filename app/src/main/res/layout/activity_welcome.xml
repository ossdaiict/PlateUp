<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.WelcomeActivity"
    android:background="@drawable/bg_gradient"
    android:fitsSystemWindows="true">

    <ScrollView
        android:id="@+id/welcomeContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <ImageView
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:src="@drawable/food_illustration"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="16dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PlateUp"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skip the queue, not the meal"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/studentBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Continue as Student"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/primary"
                app:cornerRadius="30dp"
                android:elevation="4dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="or"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/canteenBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Canteen Login"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:backgroundTint="@android:color/transparent"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp"
                app:cornerRadius="26dp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Admin Access"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/admin_auth"
                app:cornerRadius="26dp"/>

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>