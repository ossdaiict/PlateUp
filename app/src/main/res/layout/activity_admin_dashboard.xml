<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.AdminDashboardActivity"
    android:background="@drawable/bg_gradient">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/logoutBtn">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Welcome, Admin"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="24dp"
                android:text="Manage canteens and vendor access"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginStart="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/greetingText"/>

            <GridLayout
                android:id="@+id/adminDashboardGrid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/subtitleText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/createCanteenCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/primary_light"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="26dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/text_secondary"
                            app:cardBackgroundColor="@color/primary_light">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_storefront"
                                app:tint="@color/text_white"/>

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Create Canteen"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Add new canteens and vendor access"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/manageCanteensCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/admin_auth"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="26dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/text_secondary"
                            app:cardBackgroundColor="@color/admin_auth">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_build"
                                app:tint="@color/text_white"/>

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Manage Canteens"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="View and manage existing canteens"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/viewPendingRequestsCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/accent_dark"
                    app:cardBackgroundColor="@color/card_background">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                app:cardCornerRadius="26dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/text_secondary"
                                app:cardBackgroundColor="@color/accent_dark">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_pending_actions"
                                    app:tint="@color/text_white"/>

                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:text="Pending Requests"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Review vendor menu change requests"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/pendingBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="14dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/bg_close_chip"
                            android:minWidth="28dp"
                            android:gravity="center"
                            android:paddingHorizontal="9dp"
                            android:paddingVertical="4dp"
                            android:textColor="@color/error"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:text="4"
                            tools:visibility="visible"/>

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>
    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/logoutBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:text="Sign Out"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/error"
        app:strokeColor="@color/error"
        app:strokeWidth="1dp"
        android:backgroundTint="@android:color/transparent"
        app:cornerRadius="16dp"
        android:textAlignment="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nestedScrollView"
        app:layout_constraintVertical_bias="1.0"/>

</androidx.constraintlayout.widget.ConstraintLayout>
