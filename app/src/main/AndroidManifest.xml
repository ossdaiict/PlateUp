        <package android:name="com.freecharge.android" />
        <package android:name="com.application.zomato" />
        <package android:name="com.whatsapp" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PlateUp">
        <activity
            android:name=".activities.VendorSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentNotificationsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.VendorOrderDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.PickupScannerActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".activities.VendorOrdersActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentOrderDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.CartDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentMenuActivity"
            android:exported="false" />
        <activity
            android:name=".activities.VendorRequestsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminPendingRequestsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminManageCanteensActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminCanteenDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.VendorRequestMenuItemActivity"
            android:exported="false" />
        <activity
            android:name=".activities.VendorManageMenuActivity"
            android:exported="false" />
        <activity
            android:name=".activities.VendorDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".activities.VendorAuthenticationActivity"
            android:exported="false" />
        <activity
            android:name=".activities.CreateCanteenActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminAuthenticationActivity"
            android:exported="false" />
        <activity
            android:name=".activities.WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.PlateUp.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentAuthenticationActivity"
            android:exported="false" />
        <activity
            android:name=".activities.MenuItemDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.StudentDashboardActivity"
            android:exported="false" />

        <service
            android:name=".services.PlateUpMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>